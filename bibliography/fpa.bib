@inproceedings{desousaChallengesPracticalUse2024,
  title = {Challenges on the {{Practical Use}} of {{Augmented Reality}} by {{Non-technical Users}}: {{A Case Study}}},
  shorttitle = {Challenges on the {{Practical Use}} of {{Augmented Reality}} by {{Non-technical Users}}},
  booktitle = {Proceedings of the 25th {{Symposium}} on {{Virtual}} and {{Augmented Reality}}},
  author = {{de Sousa}, Igor Oliveira and Costa, Thiago Jansen Sampaio and Malheiros, Marcelo de Gomensoro and Bicho, Alessandro de Lima},
  year = {2024},
