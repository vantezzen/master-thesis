@article{whitlockInteractingDistantObjects2018,
  title = {Interacting with {{Distant Objects}} in {{Augmented Reality}}},
  author = {Whitlock, Matt and Harnner, Ethan and Brubaker, Jed R. and Kane, Shaun and Szafir, Danielle Albers},
  year = {2018},
  month = mar,
  journal = {2018 IEEE Conference on Virtual Reality and 3D User Interfaces (VR)},
  pages = {41--48},
  publisher = {IEEE},
  address = {Reutlingen},
  doi = {10.1109/VR.2018.8446381},
  urldate = {2024-12-19},
  abstract = {Augmented reality (AR) applications can leverage the full space of an environment to create immersive experiences. However, most empirical studies of interaction in AR focus on interactions with objects close to the user, generally within arms reach. As objects move farther away, the efficacy and usability of different interaction modalities may change. This work explores AR interactions at a distance, measuring how applications may support fluid, efficient, and intuitive interactive experiences in room-scale augmented reality. We conducted an empirical study (N = 20) to measure trade-offs between three interaction modalities-multimodal voice, embodied freehand gesture, and handhelds devices-for selecting, rotating, and translating objects at distances ranging from 8 to 16 feet (2.4m-4.9m). Though participants performed comparably with embodied freehand gestures and handheld remotes, they perceived embodied gestures as significantly more efficient and usable than device-mediated interactions. Our findings offer considerations for designing efficient and intuitive interactions in room-scale AR applications.},
  isbn = {9781538633656},
  annotation = {Zugriff 2024-12-19}
}

@inproceedings{wickerothManipulating3DContent2009,
  title = {Manipulating {{3D Content}} Using {{Gestures}} in {{Design Review Scenarios}}},
  author = {Wickeroth, Daniel and Ben{\"o}lken, P. and Lang, U.},
  year = {2009},
  urldate = {2024-12-04},
  abstract = {This article describes the prototype of a gesture based interface for design review scenarios and its evalua- tion. The prototype uses computer vision methods to analyze the camera images obtained from a calibrated stereo camera setup and allows for the manipulation of 3 dimensional objects with hand gestures. The gestures performed by the user are translated into commands by a gesture interaction server. The commands are sent to the client software, a renderer called ViNCE, which is a part of the COVISE visualization software. The gesture interface was evaluated in a user study with 17 participants. The evaluation results confi rmed our assumption that gestural interfaces are a valuable utility for modern designers and engineers whose primary fi eld of work includes large amounts of 3 dimensional data. In the future we will continue development of the gestural interface, by improving its reliability and broadening its functional range. Design review scenarios play a decisive role in the development and manufacturing of modern consumer goods. In the auto- motive and aerospace industries design reviews are used in a number of ways which help assess the design's ability to fulfi ll quality requirements. First of all the participating engineers are given the opportunity to gain a better understanding of the design's underlying structure. Furthermore potential problems and confl icts may be identifi ed and possible solutions can be developed. Design reviews are usually conducted on a regular basis throughout the development cycle of the product. The usefulness of virtual reality (VR) and augmented reality (AR) for design reviews has been demonstrated extensively in the past (Weidlich, Benolken, Riegel, \& Scherer, 2006) (Weidlich, Kolbig, \& Polzin, 2005). Despite enormous research efforts the immersive environments still lack appropriate interaction methods for the robust, effective and intuitive manipula- tion of 3-dimensional content. During the last years new technologies such as Nintendo's Wii and Apple's iPhone and iPod Touch have emerged, which demonstrate the potential of gesture based interfaces in a wide range of application fi elds. Gesture based interfaces have many advantages over traditional interaction devices, which are especially prominent in VR and AR environments. First of all ges- tural interfaces have the potential to increase the user's effi ciency signifi cantly by exploiting a far wider range of actions with which to manipulate a system than the traditional interfaces. Compared with other high DOF 3D input devices, hands and hand gestures provide abundant degrees of freedom (DOF) and are natural and intuitive for communication and manipulation of 3D Content. Secondly by the enabling the user to perform 3-dimensional movements, gesture based interfaces allow the data and the interface to share the same 3-dimensional space. Last of all gesture based interfaces may change any time allowing for many different confi gurations depending on functionality requirements. This may entail usability issues, but the ability to have many different controls in a relatively small space can be greatly benefi cial for system designers as well as users. The research undertaken by the University of Cologne is aimed at the development of such gestural interfaces. Accordingly the prototype presented in this document allows for the manipulation of 3-dimensional content, without physically touching any device. Furthermore the prototype was evaluated in a user study in the University of Cologne. The evaluation of the prototype helped us to gain valuable user feedback, needed for the further development of the interaction prototype. The user's feedback will be used to achieve 2 goals: fi rst of all we wanted to verify the overall approach to gestural interaction taken by the researchers, which is to mimic natural interaction with 3 dimensional contents employing only simple and ro- bust computer vision techniques. Secondly we used the user's feedback to assess the systems performance with regard to its reliability and robustness in a user study. 2. Related Work},
  keywords = {No DOI found},
  annotation = {Zugriff 2024-12-04}
}

@article{zuberbuhlerDelayPerceptionThresholds2003,
  title = {Delay Perception Thresholds in Human-Computer Interaction: Fundamentals for {{CSCW-applications}}},
  shorttitle = {Delay Perception Thresholds in Human-Computer Interaction},
  author = {Zuberb{\"u}hler, Hans-J{\"o}rg and Krueger, Helmut and K{\"u}ndig, Albert},
  year = {2003},
  doi = {10.3929/ETHZ-A-004606991},
  urldate = {2025-02-11},
  abstract = {In order to optimise resource allocation in telecommunication networks, it is important to have profound knowledge of the users' subjective perceptions of quality. By means of psychophysical methodology we examined the perception thresholds of a Quality of Service (QoS) parameter represented by the overall delay between sending information and receiving answer when interacting with a computer. The thresholds are at a delay between vocal input and visual response of 115 ({\textpm} 23) ms, and at a delay between click input and visual response of 78 ({\textpm} 14) ms (numbers in brackets stand for the 95\% confidence intervals). These two threshold values differ significantly (p=0.01) from each other, whereas age and gender of the subjects do not exert significant influence on the location of the thresholds.},
  collaborator = {{Institut f{\"u}r Hygiene und Arbeitsphysiologie Z{\"u}rich}},
