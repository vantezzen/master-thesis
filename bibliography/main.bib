  file = {/Users/bennett/Zotero/storage/DINJ72FD/Jia et al. - 2021 - Semantic-Aware Label Placement for Augmented Reality in Street View.pdf;/Users/bennett/Zotero/storage/AWBNIIZ3/1912.html}
