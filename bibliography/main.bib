@inproceedings{muhammadSuggestionBasedInteractionSystem2021a,
  title = {A {{Suggestion-Based Interaction System}} for {{Spacecraft Design}} in {{Augmented Reality}}},
  booktitle = {2021 {{IEEE Aerospace Conference}} (50100)},
  author = {Muhammad, Azeem Syed and Chandran, Krishnan and Albuquerque, Georgia and Steinicke, Frank and Gerndt, Andreas},
